{
  "name": "E-commerce Playful",
  "category": "E-commerce",
  "style": "Playful",
  "description": "Fun, vibrant e-commerce design for consumer products with engaging shopping experience",
  "colors": {
    "primary": {
      "50": "#fef7ff",
      "100": "#fdebff", 
      "200": "#fad5ff",
      "300": "#f5b3ff",
      "400": "#ee82ff",
      "500": "#e654ff",
      "600": "#d932ee",
      "700": "#bf25d0",
      "800": "#9f1ba8",
      "900": "#831b87"
    },
    "accent": {
      "50": "#fff7ed",
      "100": "#ffedd5",
      "200": "#fed7aa",
      "300": "#fdba74",
      "400": "#fb923c",
      "500": "#f97316",
      "600": "#ea580c",
      "700": "#c2410c",
      "800": "#9a3412",
      "900": "#7c2d12"
    },
    "success": "#10b981",
    "warning": "#f59e0b",
    "error": "#ef4444",
    "background": "#fef7ff",
    "surface": "#ffffff",
    "border": "#e654ff",
    "text": {
      "primary": "#831b87",
      "secondary": "#9f1ba8", 
      "muted": "#bf25d0",
      "inverse": "#ffffff"
    }
  },
  "typography": {
    "fontFamily": {
      "primary": "Comic Neue, cursive",
      "heading": "Fredoka One, cursive",
      "mono": "Fira Code, monospace"
    },
    "fontSize": {
      "xs": "0.75rem",
      "sm": "0.875rem", 
      "base": "1rem",
      "lg": "1.125rem",
      "xl": "1.25rem",
      "2xl": "1.5rem",
      "3xl": "1.875rem",
      "4xl": "2.25rem",
      "5xl": "3rem",
      "6xl": "3.75rem"
    },
    "fontWeight": {
      "light": 300,
      "normal": 400,
      "medium": 500,
      "semibold": 600,
      "bold": 700,
      "extrabold": 800
    },
    "lineHeight": {
      "tight": 1.2,
      "normal": 1.6,
      "relaxed": 1.8
    }
  },
  "spacing": {
    "0": "0",
    "1": "0.25rem",
    "2": "0.5rem",
    "3": "0.75rem",
    "4": "1rem",
    "5": "1.25rem",
    "6": "1.5rem",
    "8": "2rem",
    "10": "2.5rem",
    "12": "3rem",
    "16": "4rem",
    "20": "5rem"
  },
  "borderRadius": {
    "none": "0",
    "sm": "0.125rem",
    "base": "0.25rem",
    "md": "0.375rem",
    "lg": "0.5rem",
    "xl": "0.75rem",
    "2xl": "1rem",
    "3xl": "1.5rem",
    "full": "9999px"
  },
  "shadows": {
    "sm": "0 2px 4px 0 rgb(230 84 255 / 0.2)",
    "base": "0 4px 8px -2px rgb(230 84 255 / 0.3), 0 2px 4px -2px rgb(230 84 255 / 0.15)",
    "md": "0 8px 16px -4px rgb(230 84 255 / 0.4), 0 4px 6px -4px rgb(230 84 255 / 0.2)",
    "playful": "4px 4px 0px 0px #d932ee, 8px 8px 0px 0px #bf25d0"
  },
  "components": {
    "productCard": {
      "padding": "1.5rem",
      "borderRadius": "1.5rem",
      "border": "2px solid #e654ff",
      "shadow": "playful",
      "background": "#ffffff",
      "transform": "rotate(-1deg)",
      "hoverTransform": "rotate(0deg) scale(1.02)"
    },
    "cart": {
      "borderRadius": "1.5rem",
      "border": "3px solid #e654ff",
      "shadow": "md",
      "background": "#ffffff"
    },
    "button": {
      "height": {
        "sm": "2.5rem",
        "md": "3rem", 
        "lg": "3.5rem"
      },
      "padding": {
        "sm": "0.75rem 1.5rem",
        "md": "1rem 2rem",
        "lg": "1.25rem 2.5rem"
      },
      "borderRadius": "9999px",
      "fontWeight": "700",
      "transform": "scale(1)",
      "hoverTransform": "scale(1.05)",
      "activeTransform": "scale(0.95)"
    },
    "hero": {
      "padding": "3rem 2rem",
      "background": "linear-gradient(135deg, #fef7ff, #fdebff)",
      "borderRadius": "2rem",
      "textAlign": "center"
    },
    "category": {
      "padding": "1rem",
      "borderRadius": "1rem",
      "background": "#fdebff",
      "border": "2px solid #e654ff"
    },
    "price": {
      "fontWeight": "800",
      "fontSize": "2xl",
      "background": "linear-gradient(135deg, #e654ff, #f97316)",
      "webkitBackgroundClip": "text",
      "webkitTextFillColor": "transparent"
    }
  }
}