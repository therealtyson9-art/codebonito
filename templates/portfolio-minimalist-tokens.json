    "portfolio": {
      "gridGap": "2rem",
      "columns": {
        "sm": 1,
        "md": 2,
        "lg": 3
      }
    },
    "project": {
      "borderRadius": "0.5rem",
      "overflow": "hidden",
      "shadow": "sm",
      "hoverShadow": "md"
    },
    "button": {
      "height": "2.5rem",
      "padding": "0.75rem 1.5rem",
      "borderRadius": "0.375rem",
      "fontWeight": "500"
    },
    "card": {
      "padding": "1.5rem",
      "borderRadius": "0.5rem",
      "border": "1px",
      "shadow": "sm"
    }
