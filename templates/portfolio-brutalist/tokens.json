{
  "name": "Portfolio Brutalist",
  "category": "Portfolio",
  "style": "Brutalist",
  "description": "Raw portfolio design with concrete aesthetics and unapologetic creative presentation",
  "colors": {
    "primary": {
      "50": "#fafafa",
      "100": "#f5f5f5",
      "200": "#e5e5e5",
      "300": "#d4d4d4",
      "400": "#a3a3a3",
      "500": "#737373",
      "600": "#525252",
      "700": "#404040",
      "800": "#262626",
      "900": "#171717"
    },
    "accent": {
      "50": "#fef2f2",
      "100": "#fee2e2",
      "200": "#fecaca",
      "300": "#fca5a5",
      "400": "#f87171",
      "500": "#ef4444",
      "600": "#dc2626",
      "700": "#b91c1c",
      "800": "#991b1b",
      "900": "#7f1d1d"
    },
    "success": "#059669",
    "warning": "#d97706",
    "error": "#dc2626",
    "background": "#ffffff",
    "surface": "#f5f5f5",
    "border": "#171717",
    "text": {
      "primary": "#171717",
      "secondary": "#404040",
      "muted": "#737373",
      "inverse": "#ffffff"
    }
  },
  "typography": {
    "fontFamily": {
      "primary": "Arial Black, Arial, sans-serif",
      "heading": "Impact, Arial Black, Arial, sans-serif",
      "mono": "Courier New, monospace"
    },
    "fontSize": {
      "xs": "0.75rem",
      "sm": "0.875rem",
      "base": "1rem",
      "lg": "1.125rem",
      "xl": "1.25rem",
      "2xl": "1.5rem",
      "3xl": "1.875rem",
      "4xl": "2.25rem",
      "5xl": "3rem",
      "6xl": "3.75rem"
    },
    "fontWeight": {
      "normal": 400,
      "bold": 700,
      "black": 900
    },
    "lineHeight": {
      "tight": 1.1,
      "normal": 1.3,
      "relaxed": 1.5
    },
    "letterSpacing": {
      "tight": "-0.05em",
      "normal": "0",
      "wide": "0.1em"
    }
  },
  "spacing": {
    "0": "0",
    "1": "0.25rem",
    "2": "0.5rem",
    "3": "0.75rem",
    "4": "1rem",
    "6": "1.5rem",
    "8": "2rem",
    "10": "2.5rem",
    "12": "3rem",
    "16": "4rem",
    "20": "5rem",
    "24": "6rem"
  },
  "borderRadius": {
    "none": "0",
    "sm": "0.125rem"
  },
  "shadows": {
    "none": "none",
    "brutal": "8px 8px 0px 0px #171717",
    "brutalLg": "12px 12px 0px 0px #171717",
    "brutalRed": "8px 8px 0px 0px #dc2626"
  },
  "borders": {
    "width": {
      "2": "2px",
      "4": "4px",
      "8": "8px"
    },
    "color": "#171717"
  },
  "components": {
    "hero": {
      "padding": "4rem 2rem",
      "background": "#f5f5f5",
      "border": "8px solid #171717",
      "shadow": "brutalLg",
      "textAlign": "center"
    },
    "gallery": {
      "gridGap": "2rem",
      "columns": {
        "sm": 1,
        "md": 2,
        "lg": 3
      }
    },
    "project": {
      "borderRadius": "0",
      "overflow": "hidden",
      "shadow": "brutal",
      "border": "4px solid #171717"
    },
    "about": {
      "padding": "3rem 2rem",
      "borderRadius": "0",
      "background": "#ffffff",
      "shadow": "brutal",
      "border": "4px solid #171717"
    },
    "skill": {
      "padding": "0.5rem 1rem",
      "borderRadius": "0",
      "background": "#fee2e2",
      "color": "#991b1b",
      "fontWeight": "900",
      "fontSize": "sm",
      "textTransform": "uppercase",
      "border": "2px solid #171717"
    },
    "testimonial": {
      "padding": "2rem",
      "borderRadius": "0",
      "background": "#ffffff",
      "shadow": "brutal",
      "border": "4px solid #171717"
    },
    "contact": {
      "padding": "2rem",
      "borderRadius": "0",
      "background": "#ffffff",
      "shadow": "brutal",
      "border": "4px solid #171717"
    },
    "button": {
      "height": {
        "sm": "3rem",
        "md": "4rem",
        "lg": "5rem"
      },
      "padding": {
        "sm": "1rem 2rem",
        "md": "1.5rem 3rem",
        "lg": "2rem 4rem"
      },
      "borderRadius": "0",
      "borderWidth": "4px",
      "fontWeight": "900",
      "textTransform": "uppercase",
      "letterSpacing": "0.1em"
    },
    "nav": {
      "height": "4rem",
      "padding": "0 2rem",
      "background": "#ffffff",
      "border": "4px solid #171717"
    }
  }
}