{
  "name": "Dashboard Brutalist",
  "category": "Dashboard", 
  "style": "Brutalist",
  "description": "Raw, aggressive dashboard design with stark data presentation and concrete aesthetics for uncompromising analytics",
  "colors": {
    "primary": {
      "50": "#fafafa",
      "100": "#f5f5f5",
      "200": "#e5e5e5",
      "300": "#d4d4d4",
      "400": "#a3a3a3",
      "500": "#737373",
      "600": "#525252",
      "700": "#404040",
      "800": "#262626",
      "900": "#171717"
    },
    "accent": {
      "50": "#fefce8",
      "100": "#fef9c3",
      "200": "#fef08a",
      "300": "#fde047",
      "400": "#facc15",
      "500": "#eab308",
      "600": "#ca8a04",
      "700": "#a16207",
      "800": "#854d0e",
      "900": "#713f12"
    },
    "success": "#16a34a",
    "warning": "#eab308",
    "error": "#dc2626",
    "background": "#ffffff",
    "surface": "#f5f5f5",
    "border": "#171717",
    "text": {
      "primary": "#171717",
      "secondary": "#404040", 
      "muted": "#737373",
      "inverse": "#ffffff"
    }
  },
  "typography": {
    "fontFamily": {
      "primary": "Arial Black, Arial, sans-serif",
      "heading": "Impact, Arial Black, Arial, sans-serif", 
      "mono": "Courier New, monospace"
    },
    "fontSize": {
      "xs": "0.75rem",
      "sm": "0.875rem",
      "base": "1rem",
      "lg": "1.125rem",
      "xl": "1.25rem",
      "2xl": "1.5rem",
      "3xl": "1.875rem",
      "4xl": "2.25rem"
    },
    "fontWeight": {
      "normal": 400,
      "bold": 700,
      "black": 900
    },
    "lineHeight": {
      "tight": 1.1,
      "normal": 1.3,
      "relaxed": 1.5
    },
    "letterSpacing": {
      "tight": "-0.05em",
      "normal": "0",
      "wide": "0.1em"
    }
  },
  "spacing": {
    "0": "0",
    "1": "0.25rem",
    "2": "0.5rem",
    "3": "0.75rem", 
    "4": "1rem",
    "6": "1.5rem",
    "8": "2rem",
    "10": "2.5rem",
    "12": "3rem",
    "16": "4rem",
    "20": "5rem"
  },
  "borderRadius": {
    "none": "0",
    "sm": "0.125rem"
  },
  "shadows": {
    "none": "none",
    "brutal": "8px 8px 0px 0px #171717",
    "brutalLg": "12px 12px 0px 0px #171717",
    "brutalColor": "8px 8px 0px 0px #eab308"
  },
  "borders": {
    "width": {
      "2": "2px",
      "4": "4px", 
      "8": "8px"
    },
    "color": "#171717"
  },
  "components": {
    "sidebar": {
      "width": "16rem",
      "padding": "1.5rem",
      "background": "#f5f5f5",
      "border": "4px solid #171717",
      "shadow": "brutal"
    },
    "header": {
      "height": "4rem", 
      "padding": "0 2rem",
      "background": "#ffffff",
      "border": "4px solid #171717"
    },
    "card": {
      "padding": "2rem",
      "borderRadius": "0", 
      "border": "4px solid #171717",
      "shadow": "brutal",
      "background": "#ffffff"
    },
    "metric": {
      "padding": "1.5rem",
      "borderRadius": "0",
      "border": "4px solid #171717",
      "fontWeight": "900",
      "textTransform": "uppercase",
      "background": "#ffffff"
    },
    "chart": {
      "padding": "1.5rem",
      "borderRadius": "0",
      "border": "4px solid #171717",
      "background": "#ffffff"
    },
    "button": {
      "height": {
        "sm": "3rem",
        "md": "4rem",
        "lg": "5rem"
      },
      "padding": {
        "sm": "1rem 2rem",
        "md": "1.5rem 3rem", 
        "lg": "2rem 4rem"
      },
      "borderRadius": "0",
      "borderWidth": "4px",
      "fontWeight": "900",
      "textTransform": "uppercase",
      "letterSpacing": "0.1em"
    }
  }
}